From: opencode <opencode@example.com>
Date: Sun, 08 Mar 2026 14:33:37 +0800
Subject: [PATCH] Fix PyTorch 2.12 HostBlockPool compatibility by renaming BlockPool to NPUBlockPool

This patch renames all occurrences of BlockPool to NPUBlockPool in
CachingHostAllocator.cpp to avoid naming conflicts with PyTorch 2.12's
internal BlockPool class. This ensures compatibility when building torch_npu
against newer versions of PyTorch.

Changes made:
- Renamed struct BlockPool to struct NPUBlockPool
- Updated constructor from BlockPool() to NPUBlockPool()
- Updated all pointer references from BlockPool *pool to NPUBlockPool *pool
- Updated all reference parameters from BlockPool &pool to NPUBlockPool &pool
- Updated member variable from BlockPool blocks_pool to NPUBlockPool blocks_pool

---
diff --git a/torch_npu/csrc/core/npu/CachingHostAllocator.cpp b/torch_npu/csrc/core/npu/CachingHostAllocator.cpp
index 738b91bad..28b16da50 100644
--- a/torch_npu/csrc/core/npu/CachingHostAllocator.cpp
+++ b/torch_npu/csrc/core/npu/CachingHostAllocator.cpp
@@ -46,10 +46,10 @@ using Comparison = bool (*)(const ExpandableBlock *, const ExpandableBlock *);
 static bool BlockComparatorSize(const ExpandableBlock *a, const ExpandableBlock *b);
 static bool BlockComparatorAddress(const ExpandableBlock *a, const ExpandableBlock *b);
 
-struct BlockPool {
+struct NPUBlockPool {
     std::set<ExpandableBlock *, Comparison> blocks;
     std::set<ExpandableBlock *, Comparison> unmapped;
-    BlockPool() : blocks(BlockComparatorSize), unmapped(BlockComparatorAddress) {
+    NPUBlockPool() : blocks(BlockComparatorSize), unmapped(BlockComparatorAddress) {
     }
 };
 
@@ -57,7 +57,7 @@ struct ExpandableSegment;
 
 struct ExpandableBlock : at::HostBlock<c10_npu::NPUStream>{
     size_t requested_size{};  // memory originally requested
-    BlockPool *pool{};        // owning memory pool
+    NPUBlockPool *pool{};        // owning memory pool
     bool mapped{ true };    // is the virtual address range this Block references
                             // backed by physical pages. Always true when
                             // expandable_segment_ is null. When false
@@ -72,7 +72,7 @@ struct ExpandableBlock : at::HostBlock<c10_npu::NPUStream>{
           next(nullptr)
         {}
 
-    ExpandableBlock(const size_t size, BlockPool *pool, void *ptr)
+    ExpandableBlock(const size_t size, NPUBlockPool *pool, void *ptr)
         : HostBlock(size, ptr),
           pool(pool),
           prev(nullptr),
@@ -404,7 +404,7 @@ struct ExpandableSegment {
     // returns the actual range mapped, which may be
     // greater than requested if size is not aligned to segment_size_.
     // return size of 0 indicates OOM
-    SegmentRange map(SegmentRange range, BlockPool *pool)
+    SegmentRange map(SegmentRange range, NPUBlockPool *pool)
     {
         auto begin = segmentLeft(range.ptr);
         auto end = segmentRight(range.ptr + range.size);
@@ -543,7 +543,7 @@ private:
 };
 
 struct AllocParams {
-    AllocParams(size_t size, BlockPool *pool)
+    AllocParams(size_t size, NPUBlockPool *pool)
         : search_key(size),
           pool(pool),
           err(ACL_ERROR_NONE)
@@ -556,7 +556,7 @@ struct AllocParams {
 
     ExpandableBlock search_key;
 
-    BlockPool *pool;
+    NPUBlockPool *pool;
 
     ExpandableBlock *block{};
 
@@ -685,7 +685,7 @@ public:
     }
 
 private:
-    BlockPool blocks_pool;
+    NPUBlockPool blocks_pool;
 
     std::mutex mutex;
 
@@ -837,7 +837,7 @@ private:
     }
 
     /* * combine previously split blocks. returns the size of the subsumed block, or 0 on failure. * */
-    size_t try_merge_blocks(ExpandableBlock *dst, ExpandableBlock *src, BlockPool &pool)
+    size_t try_merge_blocks(ExpandableBlock *dst, ExpandableBlock *src, NPUBlockPool &pool)
     {
         if (!src || src->allocated_ || src->event_count_ > 0 || !src->streams_.empty() || dst->mapped != src->mapped) {
             return 0;
@@ -970,7 +970,7 @@ private:
 
     bool get_free_expandable_block(AllocParams &p)
     {
-        BlockPool &pool = *p.pool;
+        NPUBlockPool &pool = *p.pool;
         auto it = pool.blocks.lower_bound(&p.search_key);
         if (it == pool.blocks.end()) {
             return false;
@@ -1012,7 +1012,7 @@ private:
     // returns the smallest possible address in any segment
     // where there is enough free address space to fit size
     // may be composed of free and unmapped segments
-    ExpandableBlock *find_expandable_block(BlockPool *pool, size_t size)
+    ExpandableBlock *find_expandable_block(NPUBlockPool *pool, size_t size)
     {
         ExpandableBlock key(0);
 
@@ -1073,7 +1073,7 @@ private:
         TORCH_INTERNAL_ASSERT(mapped_range.ptr == to_map->ptr_ && mapped_range.size >= size,
             PTA_ERROR(ErrCode::INTERNAL));
 
-        BlockPool &pool = *to_map->pool;
+        NPUBlockPool &pool = *to_map->pool;
         pool.unmapped.erase(to_map);
         to_map->mapped = true;
 
@@ -1098,7 +1098,7 @@ private:
         return true;
     }
 
-    ExpandableBlock *try_allocate_expandable_block(BlockPool *pool, size_t size)
+    ExpandableBlock *try_allocate_expandable_block(NPUBlockPool *pool, size_t size)
     {
         ExpandableBlock *candidate = find_expandable_block(pool, size);
         // Candidate is now a list free/unmapped blocks with at least size room:

